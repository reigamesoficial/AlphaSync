# =============================================================================
# AlphaSync — VPS 5 (STAGING) — Variáveis de ambiente
# Banco, Redis e chaves SEPARADOS de produção
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=AlphaSync-Staging
APP_ENV=staging
APP_DEBUG=false
APP_VERSION=1.0.0
API_V1_PREFIX=/api/v1

# ── Segurança ─────────────────────────────────────────────────────────────────
# Use uma chave DIFERENTE da produção para staging
SECRET_KEY=SUBSTITUA_CHAVE_FORTE_STAGING_DIFERENTE_DA_PROD

# ── Banco ─────────────────────────────────────────────────────────────────────
POSTGRES_USER=alphasync_staging
POSTGRES_PASSWORD=staging_password_forte
POSTGRES_DB=alphasync_staging

# ── WhatsApp ──────────────────────────────────────────────────────────────────
# Use conta/número de teste separado
WHATSAPP_API_BASE_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v21.0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=staging_verify_token
WHATSAPP_APP_SECRET=staging_app_secret

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=SUBSTITUA_OPENAI_KEY_STAGING

# ── CORS ──────────────────────────────────────────────────────────────────────
# Staging acessível em http://VPS5_IP:8080
CORS_ORIGINS=http://VPS5_IP:8080

# ── Seed ──────────────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@staging.alphasync.app
SEED_ADMIN_PASSWORD=staging_admin_123
SEED_ADMIN_NAME=Admin Staging

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG

# ── Defaults ──────────────────────────────────────────────────────────────────
DEFAULT_TIMEZONE=America/Sao_Paulo
DEFAULT_CURRENCY=BRL
GUNICORN_WORKERS=2
