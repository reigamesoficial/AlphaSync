# =============================================================================
# AlphaSync — VPS 1 (EDGE) — Variáveis de ambiente
# Apenas configurações específicas desta VPS.
# =============================================================================

# Domínio público do painel (ex: app.suaempresa.com)
DOMAIN=app.suaempresa.com

# IP privado da VPS 2 (APP) — rede interna entre VPS
# Use o IP privado para evitar tráfego pela internet
APP_VPS2_HOST=10.0.0.2

# Porta HTTP e HTTPS
HTTP_PORT=80
HTTPS_PORT=443
