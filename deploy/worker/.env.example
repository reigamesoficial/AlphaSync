# =============================================================================
# AlphaSync — VPS 4 (WORKER) — Variáveis de ambiente
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=AlphaSync
APP_ENV=production
APP_DEBUG=false
APP_VERSION=1.0.0
API_V1_PREFIX=/api/v1

# ── Segurança ─────────────────────────────────────────────────────────────────
# DEVE ser a mesma chave que a VPS 2 (APP)
SECRET_KEY=SUBSTITUA_MESMA_CHAVE_DA_VPS_APP

# ── Banco de Dados (VPS 3) ────────────────────────────────────────────────────
# Worker precisa de acesso direto ao banco para os lembretes
DATABASE_URL=postgresql+psycopg2://alphasync:SUBSTITUA_DB_PASSWORD@VPS3_PRIVATE_IP:5432/alphasync

# ── Redis (local — mesma VPS) ─────────────────────────────────────────────────
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379/0

# Senha do Redis (usada também na configuração do container Redis acima)
REDIS_PASSWORD=SUBSTITUA_SENHA_FORTE_REDIS

# ── SCHEDULER — HABILITADO aqui ───────────────────────────────────────────────
ENABLE_SCHEDULER=true

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Defaults ──────────────────────────────────────────────────────────────────
DEFAULT_TIMEZONE=America/Sao_Paulo
DEFAULT_CURRENCY=BRL
