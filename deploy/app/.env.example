# =============================================================================
# AlphaSync — VPS 2 (APP) — Variáveis de ambiente
# Copie para .env e preencha todos os valores marcados com SUBSTITUA_
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=AlphaSync
APP_ENV=production
APP_DEBUG=false
APP_VERSION=1.0.0
API_V1_PREFIX=/api/v1

# ── Segurança ─────────────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
# DEVE ser a mesma chave em APP e WORKER
SECRET_KEY=SUBSTITUA_CHAVE_FORTE_64_CHARS_MINIMO

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Banco de Dados (VPS 3) ────────────────────────────────────────────────────
# Use o IP privado da VPS 3
DATABASE_URL=postgresql+psycopg2://alphasync:SUBSTITUA_DB_PASSWORD@VPS3_PRIVATE_IP:5432/alphasync

# ── Redis (VPS 4) ─────────────────────────────────────────────────────────────
# Use o IP privado da VPS 4
REDIS_URL=redis://VPS4_PRIVATE_IP:6379/0

# ── SCHEDULER — DESABILITADO no app (roda na VPS 4) ──────────────────────────
ENABLE_SCHEDULER=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Domínio do frontend (VPS 1)
CORS_ORIGINS=https://app.suaempresa.com

# ── WhatsApp / Meta ───────────────────────────────────────────────────────────
WHATSAPP_API_BASE_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v21.0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=SUBSTITUA_SEU_VERIFY_TOKEN
WHATSAPP_APP_SECRET=SUBSTITUA_SEU_APP_SECRET

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=SUBSTITUA_SUA_OPENAI_KEY

# ── Gunicorn ─────────────────────────────────────────────────────────────────
GUNICORN_BIND=0.0.0.0:8000
# Fórmula: 2 × vCPUs da VPS. Ex: VPS com 2 vCPU → 4 workers
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Storage / PDFs ────────────────────────────────────────────────────────────
STORAGE_PATH=storage
MEDIA_BASE_URL=https://app.suaempresa.com/media

# ── Defaults ──────────────────────────────────────────────────────────────────
DEFAULT_TIMEZONE=America/Sao_Paulo
DEFAULT_CURRENCY=BRL
