# ─────────────────────────────────────────────────────────────────────────────
# AlphaSync — Variáveis de ambiente
# Copie este arquivo para .env e preencha os valores.
# Nunca commite o arquivo .env com valores reais.
# ─────────────────────────────────────────────────────────────────────────────

# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME=AlphaSync
APP_ENV=development                  # development | staging | production
APP_DEBUG=true                       # false em produção — obrigatório
APP_VERSION=1.0.0
API_V1_PREFIX=/api/v1

# ─── Segurança ───────────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
# OBRIGATÓRIO — mínimo 32 caracteres. Não use placeholders em produção.
SECRET_KEY=SUBSTITUA_POR_UMA_CHAVE_ALEATORIA_DE_64_CHARS

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Banco de Dados ──────────────────────────────────────────────────────────
# Em produção com Docker, use o service name: postgres:5432
# Formato: postgresql+psycopg2://usuario:senha@host:porta/banco
DATABASE_URL=postgresql+psycopg2://alphasync:alphasync@localhost:5432/alphasync

# ─── Cache (Redis) ───────────────────────────────────────────────────────────
# Em produção com Docker, use o service name: redis:6379
REDIS_URL=redis://localhost:6379/0

# ─── CORS ────────────────────────────────────────────────────────────────────
# Em produção: apenas o domínio do painel — sem wildcard
# Formatos aceitos:
#   Wildcard    : CORS_ORIGINS=*
#   JSON array  : CORS_ORIGINS=["https://painel.suaempresa.com"]
#   Vírgulas    : CORS_ORIGINS=https://painel.suaempresa.com,http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Multi-tenant / Plataforma ───────────────────────────────────────────────
DEFAULT_TIMEZONE=America/Sao_Paulo
DEFAULT_CURRENCY=BRL

# ─── WhatsApp / Meta ─────────────────────────────────────────────────────────
WHATSAPP_API_BASE_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v21.0

# Token de verificação que você cadastra no painel Meta > Webhooks
WHATSAPP_WEBHOOK_VERIFY_TOKEN=seu_token_de_verificacao_aqui

# App Secret do painel Meta > Configurações do App (para validar assinatura)
WHATSAPP_APP_SECRET=seu_app_secret_aqui

# ─── IA (OpenAI) ─────────────────────────────────────────────────────────────
# Opcional. Se não configurado, o bot responde sem humanização pela IA.
# Obtido em: https://platform.openai.com/api-keys
# Modelo usado: gpt-4o-mini
OPENAI_API_KEY=

# ─── Google Calendar ─────────────────────────────────────────────────────────
GOOGLE_CALENDAR_ENABLED=false
# Caminho para o JSON de credenciais da Service Account do Google
GOOGLE_CREDENTIALS_JSON_PATH=/caminho/para/google_credentials.json

# ─── PDF / Armazenamento ─────────────────────────────────────────────────────
# URL base para acesso público a arquivos gerados (PDFs, fotos)
MEDIA_BASE_URL=https://storage.suaempresa.com
STORAGE_PATH=storage

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ─── Seed do Primeiro Admin ──────────────────────────────────────────────────
# Usado apenas pelo script: python scripts/seed_admin.py
# IMPORTANTE: altere a senha após o primeiro login em produção.
SEED_ADMIN_EMAIL=admin@alphasync.app
SEED_ADMIN_PASSWORD=changeme123
SEED_ADMIN_NAME=Admin
SEED_COMPANY_SLUG=default
SEED_COMPANY_NAME=AlphaSync

# ─────────────────────────────────────────────────────────────────────────────
# VARIÁVEIS DO DOCKER COMPOSE
# Usadas pelo docker-compose.yml para configurar os containers.
# Adicione estas ao mesmo .env quando subir com Docker.
# ─────────────────────────────────────────────────────────────────────────────

# ─── PostgreSQL container ────────────────────────────────────────────────────
POSTGRES_USER=alphasync
POSTGRES_PASSWORD=alphasync          # Use senha forte em produção
POSTGRES_DB=alphasync
POSTGRES_PORT=5432                   # Porta exposta no host (somente dev)

# ─── Redis container ─────────────────────────────────────────────────────────
REDIS_PORT=6379                      # Porta exposta no host (somente dev)

# ─── Portas expostas no host ─────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443
BACKEND_PORT=8000                    # Porta exposta do backend (somente dev)
