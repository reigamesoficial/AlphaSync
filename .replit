modules = ["python-3.12", "nodejs-20"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
APP_NAME = "AlphaSync"
APP_ENV = "development"
APP_DEBUG = "true"
APP_VERSION = "1.0.0"
API_V1_PREFIX = "/api/v1"
JWT_ALGORITHM = "HS256"
ACCESS_TOKEN_EXPIRE_MINUTES = "60"
REFRESH_TOKEN_EXPIRE_DAYS = "7"
CORS_ORIGINS = "http://localhost:3000,http://localhost:5173"
DEFAULT_TIMEZONE = "America/Sao_Paulo"
DEFAULT_CURRENCY = "BRL"
WHATSAPP_API_BASE_URL = "https://graph.facebook.com"
WHATSAPP_API_VERSION = "v21.0"
STORAGE_PATH = "storage"
LOG_LEVEL = "INFO"
SECRET_KEY = "alphasync_long_secret_key_for_jwt_at_least_32_chars_long"
SEED_ADMIN_EMAIL = "admin@alphasync.app"
SEED_ADMIN_PASSWORD = "changeme123"
SEED_ADMIN_NAME = "Admin"
SEED_COMPANY_SLUG = "default"
SEED_COMPANY_NAME = "AlphaSync"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start frontend"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload"
waitForPort = 8000

[[workflows.workflow]]
name = "Start frontend"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm run dev"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 8000
externalPort = 8000

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind=0.0.0.0:5000", "--reuse-port", "--worker-class", "uvicorn.workers.UvicornWorker", "app.main:app"]
